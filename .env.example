# Aplicação
NODE_ENV=development
PORT=3000

# Banco de Dados
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=enerdata

# EIA API
EIA_API_KEY=SUA_CHAVE_AQUI
EIA_BASE_URL=https://api.eia.gov/v2
EIA_TIMEOUT_MS=60000
# Resiliência: retry por requisição HTTP à EIA (0 = sem retry)
EIA_MAX_RETRIES=3
EIA_RETRY_DELAY_MS=1000
EIA_RETRY_MAX_DELAY_MS=60000

# Segurança
STATIC_JWT_SECRET=seu_token_estatico_super_secreto

# Throttler
THROTTLE_TTL=60
THROTTLE_LIMIT=30

# Cron - Expressão cron para sincronização (padrão: a cada 10 minutos)
# Formato: seg min hora diaDoMes mês diaDaSemana
# Exemplos:
#   "0 */10 * * * *" = a cada 10 minutos
#   "0 0 * * *"     = a cada hora
#   "0 0 */6 * *"   = a cada 6 horas
SYNC_CRON_EXPRESSION="0 */10 * * * *"
# Resiliência: retentativas do Scheduler antes de desistir e esperar o próximo cron (0 = sem retry)
SYNC_MAX_RETRIES=3
# Delay base em ms entre retentativas do Scheduler (backoff exponencial: delay * 2^tentativa)
SYNC_RETRY_DELAY_MS=5000
